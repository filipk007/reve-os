# Clay Webhook OS Configuration
# No ANTHROPIC_API_KEY needed — uses Claude Code Max subscription via CLI

# API key for authenticating Clay webhook requests
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
WEBHOOK_API_KEY=change-me

# Server settings
HOST=0.0.0.0
PORT=8000

# Worker pool settings
MAX_WORKERS=10

# Default model (opus, sonnet, haiku)
DEFAULT_MODEL=opus

# Request timeout in seconds
REQUEST_TIMEOUT=120

# Cache TTL in seconds (0 to disable)
CACHE_TTL=3600

# Claude Max subscription monthly cost (USD) for savings calculation
MAX_SUBSCRIPTION_MONTHLY_USD=200.0

# Exa API key for pre-fetch intelligence (optional — enhances signal-researcher)
EXA_API_KEY=

# Sumble API key for structured company intelligence (optional — tech stacks, contacts, jobs)
SUMBLE_API_KEY=
