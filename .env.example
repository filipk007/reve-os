# Clay Webhook OS Configuration
# No ANTHROPIC_API_KEY needed — uses Claude Code Max subscription via CLI

# API key for authenticating Clay webhook requests
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
WEBHOOK_API_KEY=change-me

# Server settings
HOST=0.0.0.0
PORT=8000

# Worker pool settings
MAX_WORKERS=10

# Default model (opus, sonnet, haiku)
DEFAULT_MODEL=opus

# Request timeout in seconds
REQUEST_TIMEOUT=120

# Cache TTL in seconds (0 to disable)
CACHE_TTL=3600

# Claude Max subscription monthly cost (USD) for savings calculation
MAX_SUBSCRIPTION_MONTHLY_USD=200.0

# CORS allowed origins (comma-separated)
# Default: https://dashboard-beta-sable-36.vercel.app,http://localhost:3000,http://localhost:3001
# ALLOWED_ORIGINS=https://dashboard-beta-sable-36.vercel.app,http://localhost:3000

# Rate limits (requests per minute per IP)
# RATE_LIMIT_WEBHOOK=60
# RATE_LIMIT_BATCH=10
# RATE_LIMIT_PIPELINE=20
# RATE_LIMIT_DEFAULT=120

# Parallel.ai API key for web intelligence (optional — website search, content extraction)
PARALLEL_API_KEY=

# Sumble API key for structured company intelligence (optional — tech stacks, contacts, jobs)
SUMBLE_API_KEY=

# DeepLine enrichment API key (email waterfall + firmographic data)
DEEPLINE_API_KEY=

# Supabase (enrichment cache + auth)
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
# Feature flags — enable when Supabase is configured
SUPABASE_CACHE_ENABLED=false
SUPABASE_AUTH_ENABLED=false
