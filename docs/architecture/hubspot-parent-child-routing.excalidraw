      "roundness": null,
      "seed": 702,
      "version": 1,
      "versionNonce": 802,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "KNOWN GAP: PARENT LISTING\nContacts listing parent org on\nLinkedIn (e.g. \"NFL\" not \"Chiefs\")\n— both signals point to parent.\nCannot auto-detect.",
      "fontSize": 12,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "KNOWN GAP: PARENT LISTING\nContacts listing parent org on\nLinkedIn (e.g. \"NFL\" not \"Chiefs\")\n— both signals point to parent.\nCannot auto-detect.",
      "lineHeight": 1.25
    },
    {
      "id": "note-dedup",
      "type": "text",
      "x": 50,
      "y": 1080,
      "width": 280,
      "height": 90,
      "angle": 0,
      "strokeColor": "#868e96",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "seed": 703,
      "version": 1,
      "versionNonce": 803,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "4-LAYER DEDUP STRATEGY\n1. Mapping Table Lookup\n2. HubSpot Search API\n3. Verify-After-Create\n4. Weekly Scan (safety net)",
      "fontSize": 12,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "4-LAYER DEDUP STRATEGY\n1. Mapping Table Lookup\n2. HubSpot Search API\n3. Verify-After-Create\n4. Weekly Scan (safety net)",
      "lineHeight": 1.25
    },
    {
      "id": "note-race",
      "type": "text",
      "x": 50,
      "y": 1200,
      "width": 280,
      "height": 90,
      "angle": 0,
      "strokeColor": "#868e96",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "seed": 704,
      "version": 1,
      "versionNonce": 804,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "RACE CONDITION GUARD\nHubSpot ~1-2s indexing delay.\nVerify step catches most dupes.\nWeekly scan is final safety net.",
      "fontSize": 12,
      "fontFamily": 1,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "RACE CONDITION GUARD\nHubSpot ~1-2s indexing delay.\nVerify step catches most dupes.\nWeekly scan is final safety net.",
      "lineHeight": 1.25
    },
