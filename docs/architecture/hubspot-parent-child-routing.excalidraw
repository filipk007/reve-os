      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "GAP: TITLE ABBREVIATION\n\"KC Chiefs\" won't match\n\"Kansas City Chiefs\" — exact\nsubstring match only in v1.",
